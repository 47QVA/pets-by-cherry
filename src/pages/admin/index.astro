---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminCounts } from '../../lib/db';

const counts = await getAdminCounts(env.DB);

const cards = [
  { label: 'Categories', value: counts.categories, href: '/admin/categories' },
  { label: 'Pets', value: counts.pets, href: '/admin/pets' },
  { label: 'Products', value: counts.products, href: '/admin/products' },
  { label: 'Simulated orders today', value: counts.ordersToday, href: '/admin/orders' }
];
---

<AdminLayout title="Dashboard">
	{counts.lowStockCount > 0 && (
		<a
			href="/admin/products"
			class="mb-4 block rounded-2xl bg-coral/10 p-4 text-sm text-ink"
		>
			<strong class="text-coral">{counts.lowStockCount}</strong> product(s) are low on stock (2 or fewer left). Review products.
		</a>
	)}

	<div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
		{cards.map((card) => (
			<a href={card.href} class="rounded-2xl bg-white p-4 ring-1 ring-ink/10 hover:ring-sage-deep sm:p-6">
				<p class="text-sm text-ink-soft">{card.label}</p>
				<p class="mt-1 font-display text-2xl text-ink sm:text-3xl">{card.value}</p>
			</a>
		))}
	</div>

	<div class="mt-8 flex flex-wrap gap-3">
		<a href="/admin/categories/new" class="rounded-full bg-sage-deep px-5 py-2.5 text-sm text-cream">
			New category
		</a>
		<a href="/admin/pet-types/new" class="rounded-full bg-sage-deep px-5 py-2.5 text-sm text-cream">
			New pet type
		</a>
		<a href="/admin/pets/new" class="rounded-full bg-coral px-5 py-2.5 text-sm text-cream">
			New pet
		</a>
		<a href="/admin/product-types/new" class="rounded-full bg-sage-deep px-5 py-2.5 text-sm text-cream">
			New product type
		</a>
		<a href="/admin/products/new" class="rounded-full bg-coral px-5 py-2.5 text-sm text-cream">
			New product
		</a>
	</div>
</AdminLayout>
