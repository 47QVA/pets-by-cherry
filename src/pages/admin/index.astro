---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminCounts } from '../../lib/db';

const counts = await getAdminCounts(env.DB);

const cards = [
  { label: 'Categories', value: counts.categories, href: '/admin/categories' },
  { label: 'Pets', value: counts.pets, href: '/admin/pets' },
  { label: 'Products', value: counts.products, href: '/admin/products' },
  { label: 'Simulated orders today', value: counts.ordersToday, href: '/admin/orders' }
];
---

<AdminLayout title="Dashboard">
	{counts.lowStockCount > 0 && (
		<a
			href="/admin/products"
			class="mb-4 block bg-accent/10 p-4 text-sm text-ink"
		>
			<strong class="text-accent">{counts.lowStockCount}</strong> product(s) are low on stock (2 or fewer left). Review products.
		</a>
	)}

	<div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
		{cards.map((card) => (
			<a href={card.href} class="bg-white p-4 border border-black/10 hover:ring-blue sm:p-6">
				<p class="text-sm text-gray">{card.label}</p>
				<p class="mt-1 font-display text-2xl text-ink sm:text-3xl">{card.value}</p>
			</a>
		))}
	</div>

	<div class="mt-8 flex flex-wrap gap-3">
		<a href="/admin/categories/new" class="bg-blue px-5 py-2.5 text-sm text-white">
			New category
		</a>
		<a href="/admin/pet-types/new" class="bg-blue px-5 py-2.5 text-sm text-white">
			New pet type
		</a>
		<a href="/admin/pets/new" class="bg-accent px-5 py-2.5 text-sm text-white">
			New pet
		</a>
		<a href="/admin/product-types/new" class="bg-blue px-5 py-2.5 text-sm text-white">
			New product type
		</a>
		<a href="/admin/products/new" class="bg-accent px-5 py-2.5 text-sm text-white">
			New product
		</a>
	</div>
</AdminLayout>
