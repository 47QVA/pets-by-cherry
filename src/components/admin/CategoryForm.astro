---
import type { Category } from '../../lib/db';
import ImageField from './ImageField.astro';

interface Props {
  action: string;
  category?: Category;
  error?: string;
}

const { action, category, error } = Astro.props;
---

<form method="POST" action={action} enctype="multipart/form-data" class="max-w-lg space-y-4">
	{error && <p class="bg-accent/10 p-3 text-sm text-gray">{error}</p>}

	<div>
		<label class="mb-1 block text-sm text-gray" for="name">Name</label>
		<input
			id="name"
			name="name"
			type="text"
			required
			value={category?.name}
			class="w-full bg-white px-4 py-2.5 border border-black/10 focus:outline-none focus:ring-2 focus:ring-blue"
		/>
	</div>

	<div>
		<label class="mb-1 block text-sm text-gray" for="slug">
			Slug <span class="text-gray/70">(leave blank to auto-generate from name)</span>
		</label>
		<input
			id="slug"
			name="slug"
			type="text"
			value={category?.slug}
			class="w-full bg-white px-4 py-2.5 border border-black/10 focus:outline-none focus:ring-2 focus:ring-blue"
		/>
	</div>

	<ImageField currentUrl={category?.icon_url ?? null} />

	<div>
		<label class="mb-1 block text-sm text-gray" for="sort_order">Sort order</label>
		<input
			id="sort_order"
			name="sort_order"
			type="number"
			value={category?.sort_order ?? 0}
			class="w-32 bg-white px-4 py-2.5 border border-black/10 focus:outline-none focus:ring-2 focus:ring-blue"
		/>
	</div>

	<button type="submit" class="bg-blue px-6 py-2.5 text-sm text-white">
		{category ? 'Save changes' : 'Create category'}
	</button>
</form>
