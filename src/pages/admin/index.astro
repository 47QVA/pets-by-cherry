---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminCounts } from '../../lib/db';

const counts = await getAdminCounts(env.DB);

const cards = [
  { label: 'Categories', value: counts.categories, href: '/admin/categories' },
  { label: 'Pets', value: counts.pets, href: '/admin/pets' },
  { label: 'Simulated orders today', value: counts.ordersToday, href: '/admin/orders' }
];
---

<AdminLayout title="Dashboard">
	<div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
		{cards.map((card) => (
			<a href={card.href} class="rounded-2xl bg-white p-6 ring-1 ring-ink/10 hover:ring-sage-deep">
				<p class="text-sm text-ink-soft">{card.label}</p>
				<p class="mt-1 font-display text-3xl text-ink">{card.value}</p>
			</a>
		))}
	</div>

	<div class="mt-8 flex flex-wrap gap-3">
		<a href="/admin/categories/new" class="rounded-full bg-sage-deep px-5 py-2.5 text-sm text-cream">
			New category
		</a>
		<a href="/admin/pet-types/new" class="rounded-full bg-sage-deep px-5 py-2.5 text-sm text-cream">
			New pet type
		</a>
		<a href="/admin/pets/new" class="rounded-full bg-coral px-5 py-2.5 text-sm text-cream">
			New pet
		</a>
	</div>
</AdminLayout>
