---
import { env } from 'cloudflare:workers';
import Layout from '../layouts/Layout.astro';
import CategoryCard from '../components/CategoryCard';
import { getCategories } from '../lib/db';

const db = env.DB;
let categories: Awaited<ReturnType<typeof getCategories>> = [];
let loadError = false;

try {
  categories = await getCategories(db);
} catch {
  loadError = true;
}
---

<Layout title="Home">
	<section class="mx-auto max-w-5xl pb-8 pt-2 sm:pt-6">
		<div class="relative min-h-[26rem] overflow-hidden rounded-[2.5rem] bg-sage-deep px-6 pt-9 sm:min-h-[30rem] sm:px-12 sm:pt-12">
			<span aria-hidden="true" class="pointer-events-none absolute left-8 top-8 text-3xl opacity-10 sm:left-10 sm:top-10">🐾</span>
			<span aria-hidden="true" class="pointer-events-none absolute right-10 top-24 text-2xl opacity-10 sm:right-16">🐾</span>
			<span aria-hidden="true" class="pointer-events-none absolute bottom-40 left-6 text-xl opacity-10">🐾</span>

			<div class="relative z-10 max-w-[15rem] sm:max-w-xs">
				<h1 class="font-display text-3xl leading-tight text-cream sm:text-4xl">
					Meet your new best friend
				</h1>
				<p class="mt-3 text-sm text-cream/90 sm:text-base">
					Browse dogs, cats, birds, fish and more. A demo store &mdash; real
					catalog, checkout is fully simulated.
				</p>
				<a
					href="#categories"
					aria-label="Browse categories"
					class="mt-6 inline-flex h-14 w-14 items-center justify-center rounded-full bg-cream text-ink shadow-lg transition-transform hover:scale-105 motion-reduce:transition-none"
				>
					<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="h-6 w-6">
						<path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</a>
			</div>

			<img
				src="/images/hero/luna-cutout.png"
				alt="Luna, a golden retriever, sitting and smiling"
				class="pointer-events-none absolute -bottom-2 right-0 h-[80%] w-auto object-contain object-bottom sm:h-[92%]"
			/>
		</div>
	</section>

	<section id="categories" class="mx-auto max-w-5xl scroll-mt-6">
		<h2 class="mb-4 font-display text-xl text-ink sm:text-2xl">Meet the family</h2>

		{loadError && (
			<p class="rounded-2xl bg-coral/10 p-4 text-ink-soft">
				Couldn't load categories. Try again.
			</p>
		)}

		{!loadError && categories.length === 0 && (
			<p class="rounded-2xl bg-white p-4 text-ink-soft ring-1 ring-ink/10">
				No categories yet, check back soon.
			</p>
		)}

		{!loadError && categories.length > 0 && (
			<div class="grid grid-cols-2 gap-4 sm:grid-cols-4 sm:gap-6">
				{categories.map((category, index) => (
					<CategoryCard
						name={category.name}
						slug={category.slug}
						photoUrl={category.icon_url}
						index={index}
					/>
				))}
			</div>
		)}
	</section>
</Layout>
