---
import '../styles/tokens.css';
import CartBadge from '../components/CartBadge';
import MobileTabBar from '../components/MobileTabBar';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} · Pets by Cherry</title>
	</head>
	<body class="min-h-screen">
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-sage-deep focus:px-4 focus:py-2 focus:text-cream"
		>
			Skip to content
		</a>

		<div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
			<div class="blob-field"></div>
		</div>

		<header class="flex items-center justify-between px-6 py-4 sm:px-10">
			<a href="/" class="font-display text-2xl text-sage-deep">Pets by Cherry</a>
			<CartBadge client:load />
		</header>

		<main id="main-content" class="px-6 pb-24 sm:px-10 sm:pb-16">
			<slot />
		</main>

		<MobileTabBar client:load currentPath={currentPath} />
	</body>
</html>

<style>
	.blob-field {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at 15% 20%, color-mix(in srgb, var(--sage) 5%, transparent) 0%, transparent 40%),
			radial-gradient(circle at 85% 10%, color-mix(in srgb, var(--paw-brown) 3%, transparent) 0%, transparent 35%),
			radial-gradient(circle at 75% 80%, color-mix(in srgb, var(--sage-deep) 4%, transparent) 0%, transparent 45%);
	}
</style>
