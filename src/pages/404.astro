---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not found">
	<section class="mx-auto max-w-md py-16 text-center">
		<h1 class="font-display text-2xl text-ink sm:text-3xl">Couldn't find that page</h1>
		<p class="mt-3 text-ink-soft">It may have been moved or doesn't exist.</p>
		<a
			href="/"
			class="mt-6 inline-block rounded-full bg-sage-deep px-6 py-3 font-medium text-cream"
		>
			Back home
		</a>
	</section>
</Layout>
