---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ProductForm from '../../../components/admin/ProductForm.astro';
import { getAllProductTypes } from '../../../lib/db';

const productTypes = await getAllProductTypes(env.DB);
const error = Astro.url.searchParams.get('error') ?? undefined;
---

<AdminLayout title="New product">
	{productTypes.length === 0 ? (
		<p class="text-ink-soft">Create a category and product type first.</p>
	) : (
		<ProductForm action="/api/admin/products" productTypes={productTypes} error={error} />
	)}
</AdminLayout>
