---
import type { Category } from '../../lib/db';

interface Props {
  action: string;
  category?: Category;
  error?: string;
}

const { action, category, error } = Astro.props;
---

<form method="POST" action={action} class="max-w-lg space-y-4">
	{error && <p class="rounded-xl bg-coral/10 p-3 text-sm text-ink-soft">{error}</p>}

	<div>
		<label class="mb-1 block text-sm text-ink-soft" for="name">Name</label>
		<input
			id="name"
			name="name"
			type="text"
			required
			value={category?.name}
			class="w-full rounded-xl bg-white px-4 py-2.5 ring-1 ring-ink/10 focus:outline-none focus:ring-2 focus:ring-sage-deep"
		/>
	</div>

	<div>
		<label class="mb-1 block text-sm text-ink-soft" for="slug">
			Slug <span class="text-ink-soft/70">(leave blank to auto-generate from name)</span>
		</label>
		<input
			id="slug"
			name="slug"
			type="text"
			value={category?.slug}
			class="w-full rounded-xl bg-white px-4 py-2.5 ring-1 ring-ink/10 focus:outline-none focus:ring-2 focus:ring-sage-deep"
		/>
	</div>

	<div>
		<label class="mb-1 block text-sm text-ink-soft" for="icon_url">Photo URL</label>
		<input
			id="icon_url"
			name="icon_url"
			type="url"
			value={category?.icon_url ?? ''}
			class="w-full rounded-xl bg-white px-4 py-2.5 ring-1 ring-ink/10 focus:outline-none focus:ring-2 focus:ring-sage-deep"
		/>
	</div>

	<div>
		<label class="mb-1 block text-sm text-ink-soft" for="sort_order">Sort order</label>
		<input
			id="sort_order"
			name="sort_order"
			type="number"
			value={category?.sort_order ?? 0}
			class="w-32 rounded-xl bg-white px-4 py-2.5 ring-1 ring-ink/10 focus:outline-none focus:ring-2 focus:ring-sage-deep"
		/>
	</div>

	<button type="submit" class="rounded-full bg-sage-deep px-6 py-2.5 text-sm text-cream">
		{category ? 'Save changes' : 'Create category'}
	</button>
</form>
