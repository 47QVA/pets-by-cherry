---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import PetTypeForm from '../../../components/admin/PetTypeForm.astro';
import { getCategories } from '../../../lib/db';

const categories = await getCategories(env.DB);
const error = Astro.url.searchParams.get('error') ?? undefined;
---

<AdminLayout title="New pet type">
	{categories.length === 0 ? (
		<p class="text-ink-soft">Create a category first.</p>
	) : (
		<PetTypeForm action="/api/admin/pet-types" categories={categories} error={error} />
	)}
</AdminLayout>
