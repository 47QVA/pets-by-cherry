---
import { env } from 'cloudflare:workers';
import Layout from '../../layouts/Layout.astro';
import PetCard from '../../components/PetCard';
import ProductCard from '../../components/ProductCard';
import { getCategories, getCategoryBySlug, getPetsByCategory, getProductsByCategory } from '../../lib/db';

const { slug } = Astro.params;
const db = env.DB;

let categories: Awaited<ReturnType<typeof getCategories>> = [];
let category: Awaited<ReturnType<typeof getCategoryBySlug>> = null;
let pets: Awaited<ReturnType<typeof getPetsByCategory>> = [];
let products: Awaited<ReturnType<typeof getProductsByCategory>> = [];
let loadError = false;

try {
  [categories, category] = await Promise.all([getCategories(db), getCategoryBySlug(db, slug!)]);
  if (category) {
    [pets, products] = await Promise.all([getPetsByCategory(db, slug!), getProductsByCategory(db, slug!)]);
  }
} catch {
  loadError = true;
}

if (!loadError && !category) {
  return Astro.redirect('/404');
}
---

<Layout title={category?.name ?? 'Category'}>
	<section class="mx-auto max-w-5xl">
		<nav aria-label="Categories" class="mb-6 flex flex-wrap gap-2">
			{categories.map((c) => (
				<a
					href={`/category/${c.slug}`}
					aria-current={c.slug === slug ? 'page' : undefined}
					class={`px-4 py-2 text-sm font-medium transition-colors ${
						c.slug === slug
							? 'bg-blue text-white'
							: 'bg-white text-gray border border-black/10 hover:bg-surface'
					}`}
				>
					{c.name}
				</a>
			))}
		</nav>

		<h1 class="mb-6 font-display font-semibold tracking-tight text-2xl text-ink sm:text-3xl">{category?.name}</h1>

		{loadError && (
			<p class="bg-accent/10 p-4 text-gray">
				Couldn't load this category. Try again.
			</p>
		)}

		{!loadError && pets.length === 0 && (
			<p class="bg-white p-4 text-gray border border-black/10">
				No pets in this category yet, check back soon.
			</p>
		)}

		{!loadError && pets.length > 0 && (
			<div class="grid grid-cols-2 gap-4 sm:grid-cols-3 sm:gap-6">
				{pets.map((pet, index) => (
					<PetCard
						client:load
						id={pet.id}
						name={pet.name}
						breed={pet.breed}
						priceCents={pet.price_cents}
						photoUrl={pet.photo_url}
						index={index}
					/>
				))}
			</div>
		)}

		{!loadError && products.length > 0 && (
			<div class="mt-10">
				<h2 class="mb-4 font-display font-semibold tracking-tight text-xl text-ink sm:text-2xl">Shop for {category?.name}</h2>
				<div class="grid grid-cols-2 gap-4 sm:grid-cols-3 sm:gap-6 lg:grid-cols-4">
					{products.map((product, index) => (
						<ProductCard
							client:load
							id={product.id}
							name={product.name}
							priceCents={product.price_cents}
							photoUrl={product.photo_url}
							stockCount={product.stock_count}
							index={index}
						/>
					))}
				</div>
			</div>
		)}
	</section>
</Layout>
