---
import { env } from 'cloudflare:workers';
import Layout from '../../layouts/Layout.astro';
import { getOrderByRef } from '../../lib/db';
import { formatPrice } from '../../lib/format';
import type { CartItem } from '../../lib/cart';

const { ref } = Astro.params;
const db = env.DB;

let order: Awaited<ReturnType<typeof getOrderByRef>> = null;
let loadError = false;

try {
  order = await getOrderByRef(db, ref!);
} catch {
  loadError = true;
}

if (!loadError && !order) {
  return Astro.redirect('/404');
}

const items: CartItem[] = order ? JSON.parse(order.items_json) : [];
---

<Layout title="Order confirmed">
	<section class="mx-auto max-w-lg">
		{loadError && (
			<p class="bg-accent/10 p-4 text-gray">
				Couldn't load this receipt. Try again.
			</p>
		)}

		{!loadError && order && (
			<>
				<div class="bg-surface p-6 text-center">
					<p class="font-display text-xl text-ink sm:text-2xl">Order confirmed 🎉</p>
					<p class="mt-1 text-gray">Demo checkout — no real payment was processed.</p>
					<p class="mt-4 font-display text-lg text-blue">{order.fake_receipt_ref}</p>
				</div>

				<ul class="mt-6 space-y-3">
					{items.map((item) => (
						<li class="flex items-center gap-4 bg-white p-3 border border-black/5">
							<div class="h-14 w-14 shrink-0 overflow-hidden bg-surface">
								{item.photoUrl && <img src={item.photoUrl} alt={item.name} class="h-full w-full object-cover" />}
							</div>
							<div class="flex-1">
								<p class="text-ink">{item.name}</p>
								{item.quantity > 1 && <p class="text-sm text-gray">Qty {item.quantity}</p>}
							</div>
							<p class="text-gray">{formatPrice(item.priceCents * item.quantity)}</p>
						</li>
					))}
				</ul>

				<div class="mt-6 flex items-center justify-between border-t border-black/10 pt-4">
					<span class="font-display text-lg text-ink">Total paid</span>
					<span class="font-display text-xl text-accent">{formatPrice(order.total_cents)}</span>
				</div>

				<div class="mt-6 bg-white p-4 border border-black/10">
					<p class="text-sm text-gray">Delivering to</p>
					<p class="text-ink">{order.fake_delivery_address}</p>
					<p class="mt-2 text-sm text-gray">Estimated delivery: 3–5 business days.</p>
				</div>

				<a
					href="/"
					class="mt-6 block bg-blue px-6 py-4 text-center font-display text-lg text-white"
				>
					Back home
				</a>
			</>
		)}
	</section>
</Layout>
