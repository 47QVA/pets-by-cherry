---
import { env } from 'cloudflare:workers';
import Layout from '../../layouts/Layout.astro';
import AddToCartButtons from '../../components/AddToCartButtons';
import { getProductById, getProductTypeById } from '../../lib/db';
import { formatPrice } from '../../lib/format';

const { id } = Astro.params;
const db = env.DB;

let product: Awaited<ReturnType<typeof getProductById>> = null;
let typeName: string | null = null;
let loadError = false;

try {
  product = await getProductById(db, Number(id));
  if (product) {
    const productType = await getProductTypeById(db, product.product_type_id);
    typeName = productType?.name ?? null;
  }
} catch {
  loadError = true;
}

if (!loadError && !product) {
  return Astro.redirect('/404');
}
---

<Layout title={product?.name ?? 'Product'}>
	<section class="mx-auto max-w-3xl">
		{loadError && (
			<p class="bg-accent/10 p-4 text-gray">
				Couldn't load this product. Try again.
			</p>
		)}

		{!loadError && product && (
			<>
				<div class="overflow-hidden bg-white border border-black/10">
					{product.photo_url ? (
						<img src={product.photo_url} alt={product.name} class="aspect-square w-full object-cover sm:aspect-video" />
					) : (
						<div class="aspect-square w-full bg-surface sm:aspect-video" />
					)}
				</div>

				<div class="mt-6 flex flex-wrap items-start justify-between gap-x-4 gap-y-2">
					<div class="min-w-0">
						<h1 class="break-words font-display font-semibold tracking-tight text-2xl text-ink sm:text-3xl">{product.name}</h1>
						{typeName && <p class="text-gray">{typeName}</p>}
					</div>
					<p class="whitespace-nowrap font-display text-xl text-accent sm:text-2xl">
						{formatPrice(product.price_cents)}
					</p>
				</div>

				{product.stock_count > 0 && product.stock_count <= 3 && (
					<p class="mt-3 text-sm text-accent">Only {product.stock_count} left</p>
				)}

				{product.description && (
					<p class="mt-6 leading-relaxed text-gray">{product.description}</p>
				)}

				{product.in_stock && product.stock_count > 0 ? (
					<AddToCartButtons
						client:load
						kind="product"
						id={product.id}
						name={product.name}
						priceCents={product.price_cents}
						photoUrl={product.photo_url}
					/>
				) : (
					<p class="mt-8 bg-white px-6 py-4 text-center text-gray border border-black/10">
						No longer available
					</p>
				)}
			</>
		)}
	</section>
</Layout>
