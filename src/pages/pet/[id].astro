---
import { env } from 'cloudflare:workers';
import Layout from '../../layouts/Layout.astro';
import AddToCartButtons from '../../components/AddToCartButtons';
import { getPetById } from '../../lib/db';
import { formatPrice } from '../../lib/format';

const { id } = Astro.params;
const db = env.DB;

let pet: Awaited<ReturnType<typeof getPetById>> = null;
let loadError = false;

try {
  pet = await getPetById(db, Number(id));
} catch {
  loadError = true;
}

if (!loadError && !pet) {
  return Astro.redirect('/404');
}

const facts = pet
  ? [
      pet.breed && { label: 'Breed', value: pet.breed },
      pet.age_label && { label: 'Age', value: pet.age_label },
      pet.weight_label && { label: 'Weight', value: pet.weight_label },
      { label: 'Vaccinated', value: pet.vaccinated ? 'Yes' : 'Not yet' }
    ].filter(Boolean)
  : [];
---

<Layout title={pet?.name ?? 'Pet'}>
	<section class="mx-auto max-w-3xl">
		{loadError && (
			<p class="rounded-2xl bg-coral/10 p-4 text-ink-soft">
				Couldn't load this pet. Try again.
			</p>
		)}

		{!loadError && pet && (
			<>
				<div class="overflow-hidden rounded-3xl bg-white ring-1 ring-ink/10">
					{pet.photo_url ? (
						<img src={pet.photo_url} alt={pet.name} class="aspect-square w-full object-cover sm:aspect-video" />
					) : (
						<div class="aspect-square w-full bg-sage sm:aspect-video" />
					)}
				</div>

				<div class="mt-6 flex flex-wrap items-start justify-between gap-x-4 gap-y-2">
					<div class="min-w-0">
						<h1 class="break-words font-display text-2xl text-ink sm:text-3xl">{pet.name}</h1>
						{pet.sex && <p class="text-ink-soft">{pet.sex}</p>}
					</div>
					<p class="whitespace-nowrap font-display text-xl text-coral sm:text-2xl">
						{formatPrice(pet.price_cents)}
					</p>
				</div>

				<div class="mt-5 flex flex-wrap gap-2">
					{facts.map((fact: any) => (
						<span class="rounded-full bg-white px-4 py-2 text-sm text-ink-soft ring-1 ring-ink/10">
							<strong class="text-ink">{fact.label}:</strong> {fact.value}
						</span>
					))}
				</div>

				{pet.description && (
					<p class="mt-6 leading-relaxed text-ink-soft">{pet.description}</p>
				)}

				{pet.in_stock && pet.stock_count > 0 ? (
					<AddToCartButtons
						client:load
						kind="pet"
						id={pet.id}
						name={pet.name}
						priceCents={pet.price_cents}
						photoUrl={pet.photo_url}
					/>
				) : (
					<p class="mt-8 rounded-full bg-white px-6 py-4 text-center text-ink-soft ring-1 ring-ink/10">
						No longer available
					</p>
				)}
			</>
		)}
	</section>
</Layout>
