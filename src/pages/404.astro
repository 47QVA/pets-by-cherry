---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not found">
	<section class="mx-auto max-w-md py-16 text-center">
		<h1 class="font-display font-semibold tracking-tight text-2xl text-ink sm:text-3xl">Couldn't find that page</h1>
		<p class="mt-3 text-gray">It may have been moved or doesn't exist.</p>
		<a
			href="/"
			class="mt-6 inline-block bg-blue px-6 py-3 font-medium text-white"
		>
			Back home
		</a>
	</section>
</Layout>
