---
interface Props {
  currentUrl?: string | null;
  label?: string;
}

const { currentUrl = null, label = 'Photo' } = Astro.props;
---

<div class="space-y-2 sm:col-span-2">
	<label class="block text-sm text-gray">{label} <span class="text-gray/70">(optional)</span></label>

	{currentUrl && (
		<img src={currentUrl} alt="Current" class="h-24 w-24 border border-black/10 object-cover" />
	)}

	<input
		type="text"
		name="photo_url"
		placeholder="Image URL or path"
		value={currentUrl ?? ''}
		class="w-full bg-white px-4 py-2.5 border border-black/10 focus:outline-none focus:ring-2 focus:ring-blue"
	/>
	<input
		type="file"
		name="photo_file"
		accept="image/*"
		class="w-full text-sm text-gray file:mr-3 file:border-0 file:bg-surface file:px-3 file:py-2 file:text-sm file:text-ink"
	/>
	<p class="text-xs text-gray">
		Paste a URL/path, or upload a picture (max 1MB). Leave both blank to
		{currentUrl ? ' keep the current image.' : ' skip adding one for now.'}
	</p>
</div>
