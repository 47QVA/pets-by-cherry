---
import { env } from 'cloudflare:workers';
import Layout from '../layouts/Layout.astro';
import CategoryCard from '../components/CategoryCard';
import { getCategories } from '../lib/db';

const db = env.DB;
let categories: Awaited<ReturnType<typeof getCategories>> = [];
let loadError = false;

try {
  categories = await getCategories(db);
} catch {
  loadError = true;
}
---

<Layout title="Home">
	<section class="relative border-b border-black/10 bg-white">
		<div class="relative mx-auto max-w-6xl px-6 pb-64 pt-10 sm:px-10 sm:pt-16 sm:pb-0">
			<!-- Image is painted before the text below, so the headline's
			     mix-blend-difference can actually blend against it where they
			     overlap (blend modes only see content painted earlier). -->
			<img
				src="/images/hero/luna-cutout.png"
				alt="Luna, a golden retriever, sitting and smiling"
				class="pointer-events-none absolute bottom-0 right-1/2 h-64 w-auto translate-x-1/2 object-contain object-bottom sm:right-0 sm:h-[28rem] sm:translate-x-0"
			/>

			<div class="relative max-w-xs sm:max-w-md sm:pb-20">
				<h1
					class="mix-blend-difference font-display font-semibold leading-[1.05] tracking-tight text-white"
					style="font-size: clamp(2rem, 6vw, 3.75rem);"
				>
					Meet your new best friend
				</h1>
				<p class="mt-4 text-base text-gray sm:text-lg">
					Browse dogs, cats, birds, fish and more. A demo store &mdash; real
					catalog, checkout is fully simulated.
				</p>
				<a
					href="#categories"
					class="mt-7 inline-flex items-center gap-2 bg-blue px-6 py-3.5 text-white transition-colors hover:bg-blue/90"
				>
					Browse categories
					<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="h-4 w-4">
						<path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</a>
			</div>
		</div>
	</section>

	<section id="categories" class="mx-auto max-w-5xl scroll-mt-6 pt-8">
		<h2 class="mb-4 font-display font-semibold tracking-tight text-xl text-ink sm:text-2xl">Meet the family</h2>

		{loadError && (
			<p class="bg-accent/10 p-4 text-gray">
				Couldn't load categories. Try again.
			</p>
		)}

		{!loadError && categories.length === 0 && (
			<p class="border border-black/10 bg-white p-4 text-gray">
				No categories yet, check back soon.
			</p>
		)}

		{!loadError && categories.length > 0 && (
			<div class="grid grid-cols-2 gap-4 sm:grid-cols-4 sm:gap-6">
				{categories.map((category, index) => (
					<CategoryCard
						name={category.name}
						slug={category.slug}
						photoUrl={category.icon_url}
						index={index}
					/>
				))}
			</div>
		)}
	</section>
</Layout>
