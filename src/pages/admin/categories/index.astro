---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getCategories } from '../../../lib/db';

const categories = await getCategories(env.DB);
---

<AdminLayout title="Categories">
	<a href="/admin/categories/new" class="mb-4 inline-block bg-blue px-5 py-2.5 text-sm text-white">
		New category
	</a>

	{categories.length === 0 ? (
		<p class="text-gray">No categories yet.</p>
	) : (
		<div class="overflow-x-auto bg-white border border-black/10">
			<table class="w-full text-left text-sm">
				<thead>
					<tr class="border-b border-black/10 text-gray">
						<th class="hidden px-4 py-3 font-medium sm:table-cell">Sort</th>
						<th class="px-4 py-3 font-medium">Name</th>
						<th class="hidden px-4 py-3 font-medium sm:table-cell">Slug</th>
						<th class="px-4 py-3 font-medium"></th>
					</tr>
				</thead>
				<tbody>
					{categories.map((category) => (
						<tr class="border-b border-black/5 last:border-0">
							<td class="hidden px-4 py-3 text-gray sm:table-cell">{category.sort_order}</td>
							<td class="px-4 py-3 text-ink">{category.name}</td>
							<td class="hidden px-4 py-3 text-gray sm:table-cell">{category.slug}</td>
							<td class="px-4 py-3 text-right">
								<a href={`/admin/categories/${category.id}/edit`} class="text-blue underline">
									Edit
								</a>
							</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	)}
</AdminLayout>
