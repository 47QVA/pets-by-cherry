---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getAllProducts } from '../../../lib/db';
import { formatPrice } from '../../../lib/format';

const products = await getAllProducts(env.DB);
---

<AdminLayout title="Products">
	<a href="/admin/products/new" class="mb-4 inline-block rounded-full bg-coral px-5 py-2.5 text-sm text-cream">
		New product
	</a>

	{products.length === 0 ? (
		<p class="text-ink-soft">No products yet.</p>
	) : (
		<div class="overflow-x-auto rounded-2xl bg-white ring-1 ring-ink/10">
			<table class="w-full text-left text-sm">
				<thead>
					<tr class="border-b border-ink/10 text-ink-soft">
						<th class="px-4 py-3 font-medium">Name</th>
						<th class="px-4 py-3 font-medium">Price</th>
						<th class="px-4 py-3 font-medium">Stock</th>
						<th class="px-4 py-3 font-medium">Visible</th>
						<th class="px-4 py-3 font-medium"></th>
					</tr>
				</thead>
				<tbody>
					{products.map((product) => (
						<tr class="border-b border-ink/5 last:border-0">
							<td class="px-4 py-3 text-ink">{product.name}</td>
							<td class="px-4 py-3 text-ink-soft">{formatPrice(product.price_cents)}</td>
							<td class={`px-4 py-3 ${product.stock_count <= 2 ? 'font-medium text-coral' : 'text-ink-soft'}`}>
								{product.stock_count}
							</td>
							<td class="px-4 py-3 text-ink-soft">{product.in_stock ? 'Yes' : 'No'}</td>
							<td class="px-4 py-3 text-right">
								<a href={`/admin/products/${product.id}/edit`} class="text-sage-deep underline">
									Edit
								</a>
							</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	)}
</AdminLayout>
