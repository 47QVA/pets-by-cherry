{
  "name": "pets-by-cherry",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "db:migrate": "node scripts/wrangler-local.mjs d1 migrations apply pets_by_cherry_db --local",
    "db:seed": "node scripts/wrangler-local.mjs d1 execute pets_by_cherry_db --local --file=./scripts/seed.sql",
    "db:query": "node scripts/wrangler-local.mjs d1 execute pets_by_cherry_db --local --command",
    "db:update-photos": "node scripts/wrangler-local.mjs d1 execute pets_by_cherry_db --local --file=./scripts/update-photos.sql",
    "types": "node node_modules/wrangler/bin/wrangler.js types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/preact": "^6.0.1",
    "@fontsource-variable/fredoka": "^5.2.10",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.7",
    "preact": "^10.29.7",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^26.1.1",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.110.0"
  }
}
